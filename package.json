{
  "name": "lunar-agent-workbench",
  "version": "1.0.0",
  "description": "Lunar Agent Workbench - an Electron AI coding assistant for DeepSeek-compatible workflows",
  "main": "./out/main/index.js",
  "author": "lunarfairy",
  "repository": {
    "type": "git",
    "url": "https://github.com/lunarfairy/lunar-agent-workbench.git"
  },
  "bugs": {
    "url": "https://github.com/lunarfairy/lunar-agent-workbench/issues"
  },
  "homepage": "https://github.com/lunarfairy/lunar-agent-workbench#readme",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --win --dir && electron-builder --win --prepackaged dist/win-unpacked",
    "package:dir": "electron-vite build && electron-builder --win --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "openai": "^4.78.0",
    "uuid": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.460.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^9.0.0",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.lunarfairy.agentworkbench",
    "productName": "Lunar Agent Workbench",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": null,
      "sign": false,
      "signingHashAlgorithms": []
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false,
      "artifactName": "Lunar-Agent-Workbench-Setup-${version}.exe"
    },
    "asar": true
  }
}
